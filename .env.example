# ============================================================
# Angel One SmartAPI Credentials
# ============================================================
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_PIN=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ============================================================
# Trading Mode
# ============================================================
# Set to False ONLY when you are ready to trade with real money
PAPER_TRADING=True

# ============================================================
# Capital & Risk
# ============================================================
CAPITAL=100000               # Total capital in INR
MAX_RISK_PER_TRADE_PCT=1.0   # Max risk per trade as % of capital (1%)
MAX_DAILY_LOSS_PCT=3.0       # Max daily loss as % of capital (3%)
MAX_OPEN_TRADES=3            # Maximum concurrent open trades
SL_PCT=30.0                  # Stop loss as % of option premium paid
TARGET_PCT=60.0              # Target as % of option premium paid
TRAIL_SL_PCT=20.0            # Trail SL by this % of premium once target 1 hit

# ============================================================
# Symbols to Trade (comma-separated)
# ============================================================
SYMBOLS=NIFTY,BANKNIFTY

# ============================================================
# Strategy Configuration
# ============================================================
# Comma-separated list of enabled strategies
# Options: trend_following, breakout, vwap_reversal
ENABLED_STRATEGIES=trend_following,breakout,vwap_reversal

# Minimum confidence score (0.0 to 1.0) to take a trade
MIN_CONFIDENCE=0.65

# ============================================================
# Database
# ============================================================
# SQLite (default): leave as-is
# Postgres: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///trading.db

# ============================================================
# Telegram Alerts (optional)
# ============================================================
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log
